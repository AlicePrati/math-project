        "id": "propositional_logic",
        "label": "Propositional Logic",
        "exercises": [
          {
            "id": "prereq_r1_logic_001",
            "question": "A light switch can only be ON (true) or OFF (false). Which of these sentences is a PROPOSITION — something that can be true or false?",
            "svgKey": "prop_statement_vs_question",
            "options": [
              "The number 7 is odd",
              "Close the door!",
              "What time is it?",
              "Maybe it will rain tomorrow"
            ],
            "correct": 0,
            "explanation": "A proposition must have a definite truth value — true or false. \"The number 7 is odd\" is true. Commands, questions, and sentences with \"maybe\" have no truth value.",
            "retry": [
              {
                "question": "Like a light switch that is either ON or OFF, a proposition is either true or false — never both, never neither. Which of these is NOT a proposition?",
                "svgKey": "prop_statement_vs_question",
                "options": [
                  "Open the window!",
                  "Rome is the capital of Italy",
                  "2 + 2 = 5",
                  "The cat is on the table"
                ],
                "correct": 0,
                "explanation": "\"Open the window!\" is a command — it has no truth value. The other three are propositions: Rome=true, 2+2=5=false, cat on table=true or false depending on facts."
              },
              {
                "question": "Which sentence can be clearly assigned as true OR false?",
                "svgKey": "prop_statement_vs_question",
                "options": [
                  "The Moon orbits the Earth",
                  "Go buy some milk",
                  "Maybe he is right",
                  "How much does it cost?"
                ],
                "correct": 0,
                "explanation": "Only \"The Moon orbits the Earth\" has a precise truth value (it is true). The others are a command, an uncertainty, and a question — none of them can be true or false."
              }
            ]
          },
          {
            "id": "prereq_r1_logic_002",
            "question": "NEGATION (¬P) flips the truth value. If P = \"It is raining\" is TRUE, the image shows what happens to ¬P. What is the value of ¬P?",
            "svgKey": "prop_negation_rain",
            "options": [
              "¬P is false",
              "¬P is true",
              "¬P is true only at night",
              "¬P depends on context"
            ],
            "correct": 0,
            "explanation": "Negation always flips the truth value. If P is true, ¬P is always false. \"It is not raining\" is false when it is actually raining.",
            "retry": [
              {
                "question": "The traffic light flips the signal: red becomes green and vice versa. If P = \"The train is on time\" is FALSE, what is ¬P?",
                "svgKey": "prop_negation_rain",
                "options": [
                  "¬P is true",
                  "¬P is false",
                  "¬P is indeterminate",
                  "¬P is true only if the delay is short"
                ],
                "correct": 0,
                "explanation": "If P is false, ¬P is always true. \"The train is NOT on time\" is true when the train is actually late."
              },
              {
                "question": "P = \"Today is Monday\" is false (it is Tuesday). What is the value of ¬P = \"Today is NOT Monday\"?",
                "svgKey": "prop_negation_rain",
                "options": [
                  "True, because today is not Monday",
                  "False, because negation makes everything false",
                  "Depends on the time of day",
                  "Cannot be determined"
                ],
                "correct": 0,
                "explanation": "¬P flips the value: P was false (it is not Monday), so ¬P is true. \"Today is NOT Monday\" is correct — it is Tuesday."
              }
            ]
          },
          {
            "id": "prereq_r1_logic_003",
            "question": "A security door opens ONLY if you insert key A AND key B together. This is like conjunction P ∧ Q. When is \"It is raining ∧ I have an umbrella\" TRUE?",
            "svgKey": "prop_and_door",
            "options": [
              "Only when it is raining AND I have an umbrella",
              "When it is raining or I have an umbrella",
              "Whenever at least one of the two is true",
              "Only when it is not raining"
            ],
            "correct": 0,
            "explanation": "P ∧ Q is true only when BOTH propositions are true. Like the door that needs two keys: one alone is not enough.",
            "retry": [
              {
                "question": "The door opens only with key A AND key B. P = \"I have a driving licence\" (true), Q = \"I have a car\" (false). What is P ∧ Q?",
                "svgKey": "prop_and_door",
                "options": [
                  "False, because Q is false",
                  "True, because P is true",
                  "True, because one of them is true",
                  "Depends on the situation"
                ],
                "correct": 0,
                "explanation": "P ∧ Q requires BOTH to be true. If even one is false, the result is false — like the door that won't open with just one key."
              },
              {
                "question": "P = \"I am enrolled\" (true), Q = \"I have paid the fee\" (true). What is P ∧ Q?",
                "svgKey": "prop_and_door",
                "options": [
                  "True, both conditions are satisfied",
                  "False, AND requires something more",
                  "Indeterminate",
                  "True only if a third condition exists"
                ],
                "correct": 0,
                "explanation": "When both propositions are true, P ∧ Q is true. With both keys the door opens!"
              }
            ]
          },
          {
            "id": "prereq_r1_logic_004",
            "question": "Two switches in parallel: just ONE of them needs to be ON to light the room. This is P ∨ Q (disjunction). When is \"I am hungry ∨ I am thirsty\" FALSE?",
            "svgKey": "prop_or_light",
            "options": [
              "Only when I am not hungry AND not thirsty",
              "When I am only hungry but not thirsty",
              "When I am both hungry and thirsty",
              "It can never be false"
            ],
            "correct": 0,
            "explanation": "P ∨ Q is false only when BOTH propositions are false. If even one is true, the result is true — like the light that turns on with either switch.",
            "retry": [
              {
                "question": "OR circuit: one switch is enough. P = \"I am studying\" (false), Q = \"I am working\" (false). What is P ∨ Q?",
                "svgKey": "prop_or_light",
                "options": [
                  "False, neither one is true",
                  "True, OR is always true",
                  "True, because one could become true",
                  "Indeterminate"
                ],
                "correct": 0,
                "explanation": "P ∨ Q is false only when both are false. If no switch is on, the light stays off."
              },
              {
                "question": "P = \"It is Sunday\" (false, it is Friday), Q = \"It is a holiday\" (false). What is P ∨ Q?",
                "svgKey": "prop_or_light",
                "options": [
                  "False, because both are false",
                  "True, because Friday is almost the weekend",
                  "True, because OR includes both cases",
                  "Depends on the calendar"
                ],
                "correct": 0,
                "explanation": "OR is false only when both are false. It is Friday and not a holiday, so both P and Q are false → P ∨ Q is false."
              }
            ]
          },
          {
            "id": "prereq_r1_logic_005",
            "question": "Event entry rule: \"(You have a ticket ∧ You are at least 18) ∨ You have a VIP pass\". Marco is 16, has a ticket but no VIP pass. Can he enter?",
            "svgKey": "prop_combo_event",
            "options": [
              "No — he has a ticket but is not 18, and has no VIP pass",
              "Yes — he has a ticket, which is enough",
              "Yes — the disjunction makes everything true",
              "Cannot be determined without more information"
            ],
            "correct": 0,
            "explanation": "Ticket=true, Age≥18=false → (true ∧ false) = false. VIP pass=false. So false ∨ false = false. Marco cannot enter. Parentheses first: AND is evaluated before OR.",
            "retry": [
              {
                "question": "Same rule: \"(Ticket ∧ Age≥18) ∨ VIP pass\". Sara is 20, has no ticket, but has a VIP pass. Can she enter?",
                "svgKey": "prop_combo_event",
                "options": [
                  "Yes — VIP pass alone is sufficient",
                  "No — she has no ticket",
                  "No — AND requires all conditions",
                  "Depends on the organiser"
                ],
                "correct": 0,
                "explanation": "(false ∧ true) = false. false ∨ true = TRUE. The VIP pass alone is enough thanks to the disjunction. Sara can enter."
              },
              {
                "question": "P = \"Grade ≥ 18\" (true), Q = \"Attendance ≥ 75%\" (false), R = \"Student with exemption\" (false). The rule is (P ∧ Q) ∨ R. Is the exam passed?",
                "svgKey": "prop_combo_event",
                "options": [
                  "No — (true ∧ false) ∨ false = false",
                  "Yes — the grade is sufficient",
                  "Yes — the disjunction saves it",
                  "Depends on the professor"
                ],
                "correct": 0,
                "explanation": "(P ∧ Q) = (true ∧ false) = false. false ∨ false = FALSE. The grade is fine but attendance is not enough, and there is no exemption — exam not passed."
              }
            ]
          }
        ]
