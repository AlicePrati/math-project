    "topics": [
      {
        "id": "propositional_logic",
        "label": "Propositional Logic",
        "exercises": [
          {
            "id": "prereq_r2_logic_001",
            "question": "The table shows all rows of ¬P ∨ Q. One row is highlighted in red. Which combination of P and Q makes ¬P ∨ Q FALSE?",
            "svgKey": "prop_truth_table_neg_or",
            "options": [
              "P=True, Q=False (¬P=False, so False ∨ False = False)",
              "P=False, Q=False (¬P=True, so True ∨ False = True)",
              "P=True, Q=True (¬P=False, so False ∨ True = True)",
              "P=False, Q=True (¬P=True, so True ∨ True = True)"
            ],
            "correct": 0,
            "explanation": "¬P ∨ Q is false only when ¬P is false AND Q is false, i.e. when P=True and Q=False. In all other cases at least one term is true.",
            "retry": [
              {
                "question": "¬P ∨ Q: if P=True and Q=True, what is the value of the expression?",
                "svgKey": "prop_truth_table_neg_or",
                "options": [
                  "True — ¬P=False but Q=True saves the OR",
                  "False — P being true makes everything false",
                  "False — ¬P is false so the whole thing is false",
                  "Depends on other factors"
                ],
                "correct": 0,
                "explanation": "¬P = False, but Q = True. False ∨ True = True. OR only needs one of the two to be true."
              },
              {
                "question": "¬P ∨ Q: if P=False and Q=False, what is the value?",
                "svgKey": "prop_truth_table_neg_or",
                "options": [
                  "True — ¬P is True, so True ∨ False = True",
                  "False — both variables are false",
                  "False — negation changes nothing",
                  "Indeterminate"
                ],
                "correct": 0,
                "explanation": "¬P = True (because P is False). True ∨ False = True. The negation turned false P into true ¬P, saving the OR."
              }
            ]
          },
          {
            "id": "prereq_r2_logic_002",
            "question": "Two formulas are LOGICALLY EQUIVALENT if they have the same truth table. A vending machine accepts €1 OR €2 coins. A friend says: \"It accepts neither €1 nor €2\". How do you write the negation of (P ∨ Q)?",
            "svgKey": "prop_demorgan_or",
            "options": [
              "¬P ∧ ¬Q — does not accept €1 AND does not accept €2",
              "¬P ∨ ¬Q — does not accept €1 OR does not accept €2",
              "¬(P ∧ Q) — does not accept both at once",
              "P ∧ Q — accepts both"
            ],
            "correct": 0,
            "explanation": "De Morgan's first law: ¬(P ∨ Q) ≡ ¬P ∧ ¬Q. Negating an OR becomes an AND of negations. \"Accepts neither €1 nor €2\" means both acceptances are negated.",
            "retry": [
              {
                "question": "¬(P ∨ Q) ≡ ? — choose the correct equivalent.",
                "svgKey": "prop_demorgan_or",
                "options": [
                  "¬P ∧ ¬Q",
                  "¬P ∨ ¬Q",
                  "P ∧ Q",
                  "¬P ∧ Q"
                ],
                "correct": 0,
                "explanation": "De Morgan: ¬(A ∨ B) = ¬A ∧ ¬B. The negation enters the brackets and the connective flips: OR → AND."
              },
              {
                "question": "P = \"It is hot\" (True), Q = \"It is humid\" (False). What is ¬(P ∨ Q)?",
                "svgKey": "prop_demorgan_or",
                "options": [
                  "False — P ∨ Q is true, so its negation is false",
                  "True — negation makes everything true",
                  "True — Q is false so NOT saves it",
                  "Indeterminate"
                ],
                "correct": 0,
                "explanation": "P ∨ Q = True ∨ False = True. ¬(True) = False. Via De Morgan: ¬P ∧ ¬Q = False ∧ True = False. Same result."
              }
            ]
          },
          {
            "id": "prereq_r2_logic_003",
            "question": "A TAUTOLOGY is a formula that is always true regardless of the values of P and Q. The image shows P ∨ ¬P: either it rains (P) or it does not (¬P). Which of these is a tautology?",
            "svgKey": "prop_tautology_excluded_middle",
            "options": [
              "P ∨ ¬P — either it rains or it does not, always true",
              "P ∧ ¬P — it rains and does not rain simultaneously, impossible",
              "P ∨ Q — depends on the values",
              "¬P ∧ ¬Q — depends on the values"
            ],
            "correct": 0,
            "explanation": "P ∨ ¬P is always true: if P is true, the first member is true; if P is false, ¬P is true — the OR can never be false. This is the \"law of excluded middle\".",
            "retry": [
              {
                "question": "Which formula is a CONTRADICTION — always false, regardless of the values of P and Q?",
                "svgKey": "prop_tautology_excluded_middle",
                "options": [
                  "P ∧ ¬P — simultaneously true and false: impossible",
                  "P ∨ ¬P — always true",
                  "P → Q — depends on values",
                  "¬(P ∨ Q) — can be true"
                ],
                "correct": 0,
                "explanation": "P ∧ ¬P would require P to be true and false at the same time — impossible. It is always false: a contradiction."
              },
              {
                "question": "Which of these is a tautology?",
                "svgKey": "prop_tautology_excluded_middle",
                "options": [
                  "(P ∧ Q) → P — if it rains AND it is windy, then it rains",
                  "P → (P ∧ Q) — if it rains, then it rains and it is windy",
                  "P ∧ Q → ¬P — contradictory",
                  "¬P → P — not always"
                ],
                "correct": 0,
                "explanation": "(P ∧ Q) → P is always true: if both are true, P is certainly true. Check with the table: an implication is false only when the antecedent is true and the conclusion is false — here P∧Q true and P false is impossible."
              }
            ]
          },
          {
            "id": "prereq_r2_logic_004",
            "question": "De Morgan's second law: ¬(P ∧ Q) ≡ ¬P ∨ ¬Q. The image shows a door that needs Key A AND Key B — but Key B is crossed out (¬Q). What must an attacker do to prevent the door from opening?",
            "svgKey": "prop_demorgan_and",
            "options": [
              "Block key A OR key B — blocking just one is enough",
              "Block both keys A and B",
              "Do nothing — AND is already secure",
              "Block the lock directly"
            ],
            "correct": 0,
            "explanation": "¬(A ∧ B) ≡ ¬A ∨ ¬B. Negating an AND means at least one of the two is false. To prevent the door from opening, blocking just ONE key is enough — consistent with De Morgan.",
            "retry": [
              {
                "question": "¬(P ∧ Q) ≡ ? — choose the correct equivalent.",
                "svgKey": "prop_demorgan_and",
                "options": [
                  "¬P ∨ ¬Q",
                  "¬P ∧ ¬Q",
                  "P ∨ Q",
                  "¬(P ∨ Q)"
                ],
                "correct": 0,
                "explanation": "De Morgan: ¬(A ∧ B) = ¬A ∨ ¬B. The negation enters and the connective flips: AND → OR."
              },
              {
                "question": "P = \"Temperature > 0°\" (False), Q = \"Humidity > 80%\" (True). What is ¬(P ∧ Q)?",
                "svgKey": "prop_demorgan_and",
                "options": [
                  "True — ¬P ∨ ¬Q = True ∨ False = True",
                  "False — one of them is true so AND is true",
                  "False — P ∧ Q is false so its negation is false",
                  "Indeterminate"
                ],
                "correct": 0,
                "explanation": "P ∧ Q = False ∧ True = False. ¬(False) = True. Via De Morgan: ¬P ∨ ¬Q = True ∨ False = True. Same result."
              }
            ]
          },
          {
            "id": "prereq_r2_logic_005",
            "question": "The image shows ¬((A∧B) ∨ (C∧D)) applied step by step. A competition rule: \"(Age≥18 ∧ Resident) ∨ (Guardian ∧ Consent)\". The negation — condition to be EXCLUDED — equals?",
            "svgKey": "prop_demorgan_nested",
            "options": [
              "(Age < 18 ∨ Not resident) ∧ (No guardian ∨ No consent)",
              "(Age < 18 ∧ Not resident) ∨ (No guardian ∧ No consent)",
              "Age < 18 ∧ Not resident ∧ No guardian ∧ No consent",
              "Age < 18 ∨ Not resident ∨ No guardian ∨ No consent"
            ],
            "correct": 0,
            "explanation": "¬((A∧B) ∨ (C∧D)) = ¬(A∧B) ∧ ¬(C∧D) [De Morgan on OR] = (¬A∨¬B) ∧ (¬C∨¬D) [De Morgan on AND]. The negation distributes by flipping every connective.",
            "retry": [
              {
                "question": "Apply De Morgan to ¬((P ∧ Q) ∨ R). What is the correct result?",
                "svgKey": "prop_demorgan_nested",
                "options": [
                  "(¬P ∨ ¬Q) ∧ ¬R",
                  "(¬P ∧ ¬Q) ∨ ¬R",
                  "¬P ∨ ¬Q ∨ ¬R",
                  "¬P ∧ ¬Q ∧ ¬R"
                ],
                "correct": 0,
                "explanation": "First apply De Morgan to the outer OR: ¬((P∧Q) ∨ R) = ¬(P∧Q) ∧ ¬R. Then De Morgan on the inner AND: ¬(P∧Q) = ¬P ∨ ¬Q. Result: (¬P ∨ ¬Q) ∧ ¬R."
              },
              {
                "question": "¬(P ∨ (Q ∧ R)) — what is the equivalent form?",
                "svgKey": "prop_demorgan_nested",
                "options": [
                  "¬P ∧ (¬Q ∨ ¬R)",
                  "¬P ∨ (¬Q ∧ ¬R)",
                  "¬P ∧ ¬Q ∧ ¬R",
                  "¬P ∨ ¬Q ∨ ¬R"
                ],
                "correct": 0,
                "explanation": "De Morgan on the outer OR: ¬P ∧ ¬(Q ∧ R). De Morgan on the inner AND: ¬(Q∧R) = ¬Q ∨ ¬R. Result: ¬P ∧ (¬Q ∨ ¬R)."
              }
            ]
          }
        ]
